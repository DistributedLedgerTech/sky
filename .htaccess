# Apache — CORS headers for stellar.toml
# Required by Stellar protocol SEP-0001
# Only needed if hosting on Apache (not needed for Cloudflare Pages)

# Enable CORS for stellar.toml
<IfModule mod_headers.c>
  <FilesMatch "stellar\.toml$">
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, OPTIONS"
    Header set Access-Control-Allow-Headers "Content-Type"
    Header set Content-Type "text/plain; charset=utf-8"
  </FilesMatch>
</IfModule>

# Rewrite /.well-known/stellar.toml to /stellar.toml if file doesn't exist in .well-known
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_URI} ^/\.well-known/stellar\.toml$
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^\.well-known/stellar\.toml$ /stellar.toml [L]
</IfModule>
